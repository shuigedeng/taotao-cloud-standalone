{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-20250514",
  "default_agent": "build",
  "lsp": {
    "java": {
      "command": [
        "java",
        "-jar",
        "C:/Users/Lenovo/AppData/Local/opencode/lsp/java-language-server.jar"
      ],
      "extensions": [
        "java"
      ],
      "settings": {
        "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx2G -Xms100m --enable-preview"
      }
    }
  },
  "permission": {
    "bash": "allow",
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "write": "allow",
    "task": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "lsp": "allow",
    "skill": "allow"
  }
}
