{
  "permissions": {
    "allow": [
      "read",
      "edit",
      "write",
      "glob",
      "grep",
      "bash",
      "lsp",
      "task",
      "question",
      "skill",
      "websearch",
      "webfetch"
    ],
    "paths": {
      "allow": [
        "src/**",
        "*.gradle",
        "gradle/**",
        ".opencode/**",
        ".claude/**",
        "*.{properties,xml,yml,yaml,json,md}"
      ],
      "deny": [
        ".env*",
        "**/gradle.properties",
        "**/secrets*",
        "**/*.cer",
        "**/*.p12",
        "**/*.jks",
        "**/*.key"
      ]
    },
    "commands": {
      "allow": [
        "./gradlew",
        "git",
        "java",
        "curl",
        "docker*"
      ]
    }
  },
  "git": {
    "autoCommit": false,
    "requireTests": false,
    "commitMessageTemplate": "type(scope): description"
  },
  "java": {
    "buildTool": "gradle",
    "version": 25,
    "compileCommand": "gradlew compileJava",
    "testCommand": "gradlew test",
    "buildCommand": "gradlew build",
    "previewFeatures": true
  }
}
