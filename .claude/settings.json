{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(gradlew *)",
      "LSP",
      "Task",
      "Question",
      "Skill",
      "WebSearch",
      "WebFetch"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./secrets/**)",
      "Read(*.{cer,p12,jks,key})",
      "Bash(rm -rf /)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "env": {
    "JAVA_TOOL_OPTIONS": "--enable-preview",
    "GRADLE_OPTS": "--enable-preview --add-exports java.base/java.lang=ALL-UNNAMED --add-exports java.base/java.util=ALL-UNNAMED"
  }
}
